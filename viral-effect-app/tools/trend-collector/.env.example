# viral-effect-app トレンド収集ツール 設定ファイル
# このファイルを .env にコピーして実際の値を設定してください

# Reddit API (https://www.reddit.com/prefs/apps で取得)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=viral-effect-collector/1.0 by YourRedditUsername

# Notion API (https://www.notion.so/my-integrations で取得)
NOTION_TOKEN=ntn_your_token_here

# 登録先 Notion DB ID (デフォルトは viral-effect-app トレンド候補 DB)
NOTION_DB_ID=34188bba-289a-81fa-b0bd-f572f137c43c
